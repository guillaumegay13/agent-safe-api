# agent-safe-api — secrets.  Copy to your secrets file and fill in:
#   mkdir -p ~/.config/agent-safe-api
#   cp secrets.env.example ~/.config/agent-safe-api/secrets.env
#   chmod 600 ~/.config/agent-safe-api/secrets.env
# Override the path with $AGENT_API_ENV. NEVER commit the real file.
#
# api.sh sources this on every call and references the values only as $VARS,
# so they never enter the agent's context.

# bearer-token services
OPENAI_API_KEY=

# basic-auth services (login + password)
SOMEAPI_LOGIN=
SOMEAPI_PASSWORD=

# token-cmd services: store the COMMAND that prints a fresh token, not a token.
# api.sh runs it via $(...) so the token is never echoed. Example:
# GCP_TOKEN_CMD=gcloud auth print-access-token --scopes=https://www.googleapis.com/auth/cloud-platform.read-only
GCP_TOKEN_CMD=
